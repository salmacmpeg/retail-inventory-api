# App
ENV_STATE=DEV
DEV_DATABASE_URL=mysql+aiomysql://retail_admin:yourpassword@localhost:3306/retail_db
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
